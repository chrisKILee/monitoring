generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum AiTool {
  claude
  codex
}

model Account {
  id                  String          @id @default(cuid())
  name                String          @unique
  alias               String?
  aiTool              AiTool          @default(claude)
  hiddenFromDashboard Boolean         @default(false)
  sortOrder           Int             @default(0)
  isActive            Boolean         @default(true)

  // Claude 수집 (Codex는 null)
  orgId               String?         @unique
  encryptedCookies    String?
  cookieExpiresAt     DateTime?
  lastFetchedAt       DateTime?
  lastError           String?

  // 구 ServiceAccount에서 흡수
  phoneAuth           String?
  isShared            String?
  note                String?

  // 멤버 동기화 추적
  lastMemberSyncedAt  DateTime?

  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  alertLogs           AlertLog[]
  usageLogs           UsageLog[]
  members             AccountMember[]
}

model Member {
  id         String          @id @default(cuid())
  email      String          @unique
  name       String?
  department String?
  title      String?
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  accounts   AccountMember[]
}

model AccountMember {
  id        String   @id @default(cuid())
  accountId String
  memberId  String
  syncedAt  DateTime @default(now())
  account   Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  member    Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([accountId, memberId])
  @@index([accountId])
  @@index([memberId])
  @@map("account_member")
}

// ====================================================================
// 백업 테이블 — 2026-05-22 마이그레이션 직전 스냅샷 보존용
// 한 달 후 안전 확인되면 DROP TABLE로 정리
// ====================================================================

model MemberLegacy20260522 {
  id         String   @id
  name       String
  department String?
  purpose    String?
  createdAt  DateTime
  updatedAt  DateTime

  @@map("Member_legacy_20260522")
}

model ServiceAccountLegacy20260522 {
  id          String   @id
  accountName String
  phoneAuth   String?
  isShared    String?
  note        String?
  service     String
  createdAt   DateTime
  updatedAt   DateTime
  accountId   String?
  alias       String?

  @@map("service_account_legacy_20260522")
}

model MemberServiceAccountLegacy20260522 {
  id               String    @id
  memberId         String
  serviceAccountId String
  startDate        DateTime?
  endDate          DateTime?
  createdAt        DateTime
  updatedAt        DateTime

  @@map("member_service_account_legacy_20260522")
}

model UsageLog {
  id                  String    @id @default(cuid())
  accountId           String
  rawResponse         Json
  usedMessages        Int?
  totalMessages       Int?
  usagePercent        Float?
  expiresAt           DateTime?
  planName            String?
  resetAt             DateTime?
  predictExceed5h     Boolean   @default(false)
  predictExceed7d     Boolean   @default(false)
  fetchedAt           DateTime  @default(now())
  resetAt5h           DateTime?
  resetAt7d           DateTime?
  resetAt7dSonnet     DateTime?
  utilization5h       Int?
  utilization7d       Int?
  utilization7dSonnet Int?
  account             Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId, fetchedAt(sort: Desc)])
}

model AppUser {
  id          String          @id @default(cuid())
  email       String          @unique
  name        String?
  image       String?
  role        String          @default("user")
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  permissions UserPermission?

  @@map("app_user")
}

model UserPermission {
  id              String  @id @default(cuid())
  userId          String  @unique
  membersRead     Boolean @default(false)
  membersWrite    Boolean @default(false)
  serviceAccRead  Boolean @default(false)
  serviceAccWrite Boolean @default(false)
  monitoringRead  Boolean @default(false)
  monitoringWrite Boolean @default(false)
  user            AppUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_permission")
}

model AlertLog {
  id        String   @id @default(cuid())
  accountId String?
  alertType String
  message   String
  sentAt    DateTime @default(now())
  account   Account? @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId, sentAt(sort: Desc)])
  @@index([alertType, sentAt(sort: Desc)])
}

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt

  @@map("setting")
}
