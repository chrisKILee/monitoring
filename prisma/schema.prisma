generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Account {
  id               String           @id @default(cuid())
  name             String
  orgId            String           @unique
  encryptedCookies String
  isActive         Boolean          @default(true)
  lastFetchedAt    DateTime?
  lastError        String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  cookieExpiresAt  DateTime?
  alias            String?
  sortOrder        Int              @default(0)
  alertLogs        AlertLog[]
  usageLogs        UsageLog[]
  serviceAccounts  ServiceAccount[]
}

model ServiceAccount {
  id          String                 @id @default(cuid())
  accountName String                 @unique
  phoneAuth   String?
  isShared    String?
  note        String?
  service     String
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
  accountId   String?
  alias       String?
  memberLinks MemberServiceAccount[]
  account     Account?               @relation(fields: [accountId], references: [id])

  @@index([accountId])
  @@map("service_account")
}

model Member {
  id              String                 @id @default(cuid())
  name            String
  department      String?
  purpose         String?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
  serviceAccounts MemberServiceAccount[]
}

model MemberServiceAccount {
  id               String         @id @default(cuid())
  memberId         String
  serviceAccountId String
  startDate        DateTime?
  endDate          DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  member           Member         @relation(fields: [memberId], references: [id], onDelete: Cascade)
  serviceAccount   ServiceAccount @relation(fields: [serviceAccountId], references: [id], onDelete: Cascade)

  @@unique([memberId, serviceAccountId])
  @@index([serviceAccountId])
  @@index([endDate])
  @@map("member_service_account")
}

model UsageLog {
  id                  String    @id @default(cuid())
  accountId           String
  rawResponse         Json
  usedMessages        Int?
  totalMessages       Int?
  usagePercent        Float?
  expiresAt           DateTime?
  planName            String?
  resetAt             DateTime?
  predictExceed5h     Boolean   @default(false)
  predictExceed7d     Boolean   @default(false)
  fetchedAt           DateTime  @default(now())
  resetAt5h           DateTime?
  resetAt7d           DateTime?
  resetAt7dSonnet     DateTime?
  utilization5h       Int?
  utilization7d       Int?
  utilization7dSonnet Int?
  account             Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId, fetchedAt(sort: Desc)])
}

model AppUser {
  id          String          @id @default(cuid())
  email       String          @unique
  name        String?
  image       String?
  role        String          @default("user")
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  permissions UserPermission?

  @@map("app_user")
}

model UserPermission {
  id              String  @id @default(cuid())
  userId          String  @unique
  membersRead     Boolean @default(false)
  membersWrite    Boolean @default(false)
  serviceAccRead  Boolean @default(false)
  serviceAccWrite Boolean @default(false)
  monitoringRead  Boolean @default(false)
  monitoringWrite Boolean @default(false)
  user            AppUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_permission")
}

model AlertLog {
  id        String   @id @default(cuid())
  accountId String?
  alertType String
  message   String
  sentAt    DateTime @default(now())
  account   Account? @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId, sentAt(sort: Desc)])
  @@index([alertType, sentAt(sort: Desc)])
}

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt

  @@map("setting")
}
